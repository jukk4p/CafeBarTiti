
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /gallery/{galleryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /reservas/{reservationId} {
      // Permitimos crear reservas a cualquiera
      allow create: if true;
      // Permitimos listar para que el calendario pueda marcar días como "Ocupados"
      allow get, list: if true;
      // Solo el admin puede borrar o modificar reservas existentes
      allow write: if isAdmin();
    }
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if true;
      allow write: if isAdmin();
    }
    match /suggestions/{suggestionId} {
      allow create: if true;
      allow get, list, write: if isAdmin();
    }
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow write: if false;
    }
  }
}
